{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "overrides": [
    {
      "files": [
        "src/components/**",
        "src/features/*/ui/**",
        "src/features/*/client/**",
        "src/shared/client/**"
      ],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["~/features/*/server/**"],
                "message": "Server-only feature module — keep UI imports under features/*/ui or features/*/shared."
              },
              {
                "group": ["~/shared/server/**"],
                "message": "Server-only shared module — use ~/shared/iso or ~/shared/client from UI code."
              },
              { "group": ["~/worker/**"], "message": "Server-only worker boot." },
              { "group": ["~/agents/**"], "message": "Server-only agent code." },
              { "group": ["~/sources/**"], "message": "Server-only source adapters." }
            ]
          }
        ]
      }
    }
  ]
}
