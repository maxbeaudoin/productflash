{
  "name": "productflash",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev",
    "predev": "pnpm theme:gen",
    "build": "vite build",
    "prebuild": "pnpm theme:gen",
    "theme:gen": "tsx scripts/gen-theme-css.ts",
    "postinstall": "bash scripts/install-gitleaks.sh",
    "start": "node .output/server/index.mjs",
    "preview": "vite preview",
    "worker": "tsx --watch src/worker/index.ts",
    "worker:start": "tsx src/worker/index.ts",
    "routes:gen": "tsr generate",
    "typecheck": "tsr generate && tsgo --noEmit",
    "env:lint": "tsx scripts/env-lint.ts",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "db:psql": "./scripts/db.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "ingest:run": "tsx scripts/run-ingest.ts",
    "score:run": "tsx scripts/run-score.ts",
    "synthesize:run": "tsx scripts/run-synthesize.ts",
    "fte:run": "tsx scripts/run-fte.ts",
    "discovery:run": "tsx scripts/run-discovery.ts",
    "webpage:run": "tsx scripts/run-webpage-watcher.ts",
    "send:run": "tsx scripts/run-send.ts",
    "send:dispatch": "tsx scripts/run-send-dispatch.ts",
    "email:preview": "tsx scripts/preview-email.tsx"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
