# Product Flash — environment variables
# Copy to `.env` and fill in. Worker and web both read this file in dev.
#
# Railway sets these via the dashboard in prod (one service config per env).
# Two Railway services share the same DATABASE_URL, ANTHROPIC_API_KEY, etc.

# --- runtime ---
NODE_ENV=development
LOG_LEVEL=info
# `production` enables JSON logs; anything else uses pino-pretty.

# --- Neon Postgres ---
# Get from console.neon.tech > Project > Connection details.
# Use the pooled (-pooler) URL for the web service and the direct URL for migrations.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# Direct (non-pooler) URL — required by the FTE SSE handler (#29) for
# LISTEN/NOTIFY, which doesn't survive PgBouncer txn pooling. Same project,
# different host (drop "-pooler"). If unset, code falls back to DATABASE_URL.
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# --- Anthropic ---
# console.anthropic.com > API keys
ANTHROPIC_API_KEY=

# --- Resend ---
# resend.com > API Keys; from address must use a verified domain.
RESEND_API_KEY=
RESEND_FROM=Product Flash <noreply@productflash.ai>

# --- PostHog ---
# us.posthog.com or eu.posthog.com > project settings → "Project API key"
# (shown in the dashboard as the project token). One value drives both the
# server-side worker/captures (posthog-node) and the client-side landing
# pageviews + identify (posthog-js). The VITE_ prefix is required for Vite
# to inline the value into the browser bundle; Node reads the same var
# server-side via process.env. Leave unset in dev to make every capture a
# silent no-op.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# --- Sources ---
# Firehose: api.firehose.com (rule-based SSE, see docs/firehose.md)
# Management key (fhm_...) — only used by scripts/firehose-bootstrap-tap.ts
# to create the tap. Day-to-day adapter calls don't need it.
FIREHOSE_MANAGEMENT_KEY=
# Tap token (fh_...) — used by rule sync + stream adapter. Printed by
# scripts/firehose-bootstrap-tap.ts after a successful tap create.
# (The tap is identified by the token itself; no separate tap_id needed.)
FIREHOSE_TAP_TOKEN=
# Firecrawl: docs.firecrawl.dev
FIRECRAWL_API_KEY=
# Product Hunt: api.producthunt.com/v2 (developer token)
PRODUCT_HUNT_TOKEN=

# --- Feedback links ---
# 32+ char random string used to HMAC-sign /r/:item/:rating URLs.
# Generate with: openssl rand -hex 32
FEEDBACK_SIGNING_SECRET=

# --- Invite links (task #34) ---
# 32+ char random string used to HMAC-sign /signup?invite=<token> URLs
# issued from /admin/waitlist. Separate from FEEDBACK_SIGNING_SECRET so a
# leak of one doesn't grant invite issuance.
# Generate with: openssl rand -hex 32
INVITE_TOKEN_SECRET=

# --- Better Auth (task #26) ---
# 32+ char random string used by Better Auth to sign sessions + magic-link
# tokens. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
# Base URL for callback links. Local dev: http://localhost:3000.
# Production: the Railway-issued domain (https://...up.railway.app).
BETTER_AUTH_URL=http://localhost:3000

# --- Admin basic auth (task #16) ---
ADMIN_USER=admin
ADMIN_PASSWORD=

# --- Worker scheduling ---
# Off by default — deploys don't auto-fire the daily ingestion cron, so
# Firehose / Firecrawl / PH quota isn't spent without intent. Flip to "1"
# when ready to dogfood (and redeploy the worker). Manual triggers
# (pnpm ingest:run) work either way.
INGEST_SCHEDULE_ENABLED=
