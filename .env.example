# Tag legend (consumed by `pnpm env:lint`):
#   @public  — exposed to the browser (VITE_*). Must be in .env.production.
#   @private — backend-only, non-secret. Must be in .env.production.
#   @secret  — backend-only, sensitive. Lives in Railway; never in .env.production.

# @private
NODE_ENV=development
# @private
LOG_LEVEL=info

# @secret
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# @secret
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# @secret
ANTHROPIC_API_KEY=

# @secret
RESEND_API_KEY=
# @private
RESEND_FROM=Product Flash <noreply@productflash.ai>

# @public
VITE_POSTHOG_KEY=
# @public
VITE_POSTHOG_HOST=https://us.i.posthog.com

# @secret
FIRECRAWL_API_KEY=

# @secret
FEEDBACK_SIGNING_SECRET=
# @secret
INVITE_TOKEN_SECRET=

# @secret
BETTER_AUTH_SECRET=
# @private
BETTER_AUTH_URL=http://localhost:3000

# @secret
GOOGLE_CLIENT_ID=
# @secret
GOOGLE_CLIENT_SECRET=

# @private
INGEST_SCHEDULE_ENABLED=0
# @private
SYNTHESIS_FEEDBACK_SIGNAL_ENABLED=0

# @private
OTEL_ENABLED=0
# @private
OTEL_SERVICE_NAME=productflash
# @private
OTEL_EXPORTER_OTLP_ENDPOINT=https://cloud.langfuse.com/api/public/otel
# @secret
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(public_key:secret_key)>
